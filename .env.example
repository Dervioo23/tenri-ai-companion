# LLM Provider Configuration
# LLM_PROVIDER=groq or gemini
LLM_PROVIDER=groq
LLM_STREAMING=true  # generic streaming flag; GROQ_STREAMING is still supported
LIVE_PROMPT_MODE=true  # compact prompt for live voice turns
DEMO_SAFE_MODE=true  # safer mic and recording defaults for live demos
LLM_MAX_TOKENS=180
RESPONSE_MAX_SENTENCES=2
LIVE_RESPONSE_MAX_CHARS=260  # normal live answers; set 0 to disable character cap
PIPELINE_TRACE_ENABLED=true  # stage metadata only; no transcript or response text

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_LIVE_MODEL=llama-3.1-8b-instant  # optional faster live model; falls back to GROQ_MODEL
GROQ_STREAMING=true  # legacy alias; prefer LLM_STREAMING above
LIVE_RESPONSE_MODE=false  # true = max 1 sentence for very fast demo mode

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_ENABLED=true
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Default voice (Rachel) or your custom voice ID
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_OPTIMIZE_LATENCY=3
ELEVENLABS_VOICE_SPEED=1.08
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.65
ELEVENLABS_USE_SPEAKER_BOOST=false
ELEVENLABS_CONNECT_TIMEOUT=4.0
ELEVENLABS_READ_TIMEOUT=12.0
ELEVENLABS_CIRCUIT_BREAKER_SECONDS=60.0
TTS_PREWARM_ENABLED=false
# --- TAHAP 2: WebSocket streaming TTS (suara pertama ~0,5s, bukan tunggu MP3 utuh) ---
# true = stream PCM via WebSocket. Butuh: pip install websockets. Gagal -> fallback
# otomatis ke REST/edge-tts. Cache SHA256 frasa statis tetap di jalur REST.
ELEVENLABS_STREAMING=false
ELEVENLABS_STREAM_OUTPUT_FORMAT=pcm_22050  # pcm_16000 / pcm_22050 / pcm_24000 / pcm_44100
ELEVENLABS_STREAM_AUTO_MODE=true  # lower latency for complete phrases/sentences
ELEVENLABS_STREAM_INACTIVITY_TIMEOUT=20
ELEVENLABS_STREAM_USE_PROXY=false  # direct connection; set true only if venue requires a proxy

# General Configuration
APP_LANGUAGE=id  # 'id' (Indonesian), 'en' (English), or 'bilingual'
# 'bilingual' = mode auto: TTS membiarkan model multilingual mendeteksi bahasa
# sendiri (tanpa language_code), STT memakai bahasa utama Indonesia.
VOICE_INPUT_ENABLED=true  # Set to false to force text input fallback
VOICE_OUTPUT_ENABLED=true  # Set to false to disable ElevenLabs voice output
VISION_ENABLED=false  # Set to true to enable OpenCV vision trigger
PUSH_TO_TALK_ENABLED=true  # false = auto-listen (presenter mode, no Enter needed)
AUDIO_PLAYBACK_TIMEOUT=60.0  # Max seconds to wait before stopping stuck audio playback
LOCAL_TTS_ENABLED=true
LOCAL_TTS_ENGINE=auto  # auto = Windows SAPI offline first, then edge-tts
LOCAL_TTS_VOICE=id-ID-GadisNeural
LOCAL_TTS_TIMEOUT_SECONDS=8.0
LOCAL_TTS_SAPI_VOICE=

# Speech Recognition Settings
MIC_DEVICE_INDEX=  # Leave empty for system default, or set a microphone index
SPEECH_ENERGY_THRESHOLD=700
SPEECH_DYNAMIC_ENERGY=false
SPEECH_PAUSE_THRESHOLD=1.1
SPEECH_PHRASE_THRESHOLD=0.45
AUTO_LISTEN_PHRASE_THRESHOLD=0.25
SPEECH_NON_SPEAKING_DURATION=0.5
SPEECH_TIMEOUT=7.0
SPEECH_PHRASE_TIME_LIMIT=6.0
SPEECH_STT_AUDIO_HARD_LIMIT=6.0
SPEECH_AMBIENT_NOISE_DURATION=0.8

# Demo-recommended values (noisier room, faster pacing):
# SPEECH_ENERGY_THRESHOLD=800
# SPEECH_DYNAMIC_ENERGY=false
# SPEECH_PAUSE_THRESHOLD=1.1
# SPEECH_PHRASE_THRESHOLD=0.45
# SPEECH_NON_SPEAKING_DURATION=0.5
# SPEECH_PHRASE_TIME_LIMIT=6.0
# SPEECH_STT_AUDIO_HARD_LIMIT=6.0

# --- Silero VAD (TAHAP 1): neural endpointing menggantikan gerbang energi ---
# true = pakai VadListener (Silero ONNX). Butuh: pip install onnxruntime
# dan model di assets/models/silero_vad.onnx. Jika gagal -> fallback otomatis
# ke endpointing energi. Lebih sigap & tahan noise; threshold energi tak relevan.
SILERO_VAD_ENABLED=false
# SILERO_VAD_START_PROB=0.5     # probabilitas membuka ucapan
# SILERO_VAD_END_PROB=0.35      # probabilitas menutup ucapan (histeresis)
# SILERO_VAD_HANGOVER_MS=500    # hening sebelum ucapan dianggap selesai
# SILERO_VAD_MIN_SPEECH_MS=250  # ucapan lebih pendek dibuang sebagai blip
# SILERO_VAD_PREROLL_MS=200     # audio sebelum onset agar awal kata tak terpotong
# SILERO_VAD_STARTUP_TIMEOUT=1.5 # fallback jika stream tak mengirim frame
